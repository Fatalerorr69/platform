#!/bin/bash
set -e

LOG="/root/nvme-installer.log"
exec > >(tee -a $LOG) 2>&1

CONFIG="config.json"

apt update
apt install -y jq wget xz-utils python3 python3-flask screen util-linux coreutils

IMAGE_URL=$(jq -r .image_url $CONFIG)
TARGET_DISK=$(jq -r .target_disk $CONFIG)
HOSTNAME=$(jq -r .hostname $CONFIG)
USERNAME=$(jq -r .username $CONFIG)
PASSWORD=$(jq -r .password $CONFIG)
TIMEZONE=$(jq -r .timezone $CONFIG)
LOCALE=$(jq -r .locale $CONFIG)
PACKAGES=$(jq -r '.packages[]' $CONFIG)
BACKUP=$(jq -r .backup $CONFIG)
AUTO_REBOOT=$(jq -r .auto_reboot $CONFIG)
WEB_PORT=$(jq -r .web_port $CONFIG)

ROOT_DISK=$(findmnt / -o SOURCE -n | sed 's/[0-9]*$//')

if [ "$ROOT_DISK" = "$TARGET_DISK" ]; then
  echo "CHYBA: Nelze přepsat disk ze kterého běží systém!"
  exit 1
fi

echo "[INFO] Spouštím Web UI..."
python3 webui.py &

screen -dmS nvmeinstaller bash -c "
echo '[INFO] Stahuji image'
wget -O image.img.xz $IMAGE_URL

echo '[INFO] Flashuji NVMe'
xzcat image.img.xz | dd of=$TARGET_DISK bs=4M status=progress conv=fsync
sync
partprobe $TARGET_DISK
sleep 5

mkdir -p /mnt/rpi
mount ${TARGET_DISK}p2 /mnt/rpi
mount ${TARGET_DISK}p1 /mnt/rpi/boot

for fs in proc sys dev; do mount --bind /$fs /mnt/rpi/$fs; done

echo '[INFO] Konfigurace OS'
chroot /mnt/rpi /bin/bash <<EOF
echo '$HOSTNAME' > /etc/hostname
echo '127.0.1.1 $HOSTNAME' >> /etc/hosts

apt update
apt install -y $PACKAGES

useradd -m -s /bin/bash $USERNAME || true
echo '$USERNAME:$PASSWORD' | chpasswd
usermod -aG sudo $USERNAME

echo '$LOCALE UTF-8' > /etc/locale.gen
locale-gen
update-locale LANG=$LOCALE

ln -sf /usr/share/zoneinfo/$TIMEZONE /etc/localtime
dpkg-reconfigure -f noninteractive tzdata

systemctl enable ssh
systemctl enable ufw
ufw allow ssh
ufw --force enable
systemctl enable fail2ban
EOF

for fs in dev sys proc; do umount /mnt/rpi/$fs; done
umount /mnt/rpi/boot
umount /mnt/rpi

if [ '$BACKUP' = 'true' ]; then
  echo '[INFO] Záloha systému'
  mkdir -p /root/nvme-backup
  mount ${TARGET_DISK}p2 /mnt/rpi
  tar -czvf /root/nvme-backup/backup_\$(date +%F).tar.gz /mnt/rpi
  umount /mnt/rpi
fi

echo '[DONE] Instalace dokončena'

if [ '$AUTO_REBOOT' = 'true' ]; then
  echo '[INFO] Reboot za 30s'
  sleep 30
  reboot
fi
"

echo "[INFO] Instalace běží na pozadí (screen)"
echo "Web UI: http://$(hostname -I | awk '{print $1}'):$WEB_PORT"


