/opt/installer-web-secure/app.py

from flask import Flask,render_template,request,redirect
from flask_login import LoginManager,login_user,login_required,logout_user,UserMixin,current_user
import subprocess,psutil,json,os,bcrypt,datetime

app=Flask(__name__)
app.secret_key="CHANGE_ME"

login_manager=LoginManager(app)
login_manager.login_view="login"

CONFIG=json.load(open("/root/config.json"))
PORT=CONFIG["webui_port"]

USERS=json.load(open("/opt/installer-web-secure/users.json"))
LOG="/root/install.log"
AI="/srv/ai/mode.txt"
AUDIT="/var/log/installer-web-audit.log"

class User(UserMixin):
    def __init__(self,u,r): self.id=u; self.role=r

@login_manager.user_loader
def load_user(uid):
    if uid in USERS:
        return User(uid, USERS[uid]["role"])
    return None

def audit(msg):
    with open(AUDIT,"a") as f:
        f.write(f"{datetime.datetime.now()} {current_user.id} {msg}\n")

@app.route("/login",methods=["GET","POST"])
def login():
    if request.method=="POST":
        u=request.form["username"]
        p=request.form["password"].encode()
        if u in USERS and bcrypt.checkpw(p, USERS[u]["password"].encode()):
            login_user(User(u, USERS[u]["role"]))
            audit("LOGIN")
            return redirect("/")
    return render_template("login.html")

@app.route("/")
@login_required
def index():
    log=open(LOG).read()[-6000:] if os.path.exists(LOG) else ""
    ai=open(AI).read().strip() if os.path.exists(AI) else "N/A"

    services={}
    for s in ["docker","nginx","ssh","ufw"]:
        try: services[s]=subprocess.check_output(["systemctl","is-active",s]).decode().strip()
        except: services[s]="unknown"

    return render_template("index.html",log=log,ai=ai,services=services,role=current_user.role)

@app.route("/set_ai",methods=["POST"])
@login_required
def set_ai():
    if current_user.role!="admin": return "Forbidden",403
    mode=request.form["mode"]
    os.makedirs("/srv/ai",exist_ok=True)
    open(AI,"w").write(mode)
    audit(f"SET_AI {mode}")
    return redirect("/")

@app.route("/backup")
@login_required
def backup():
    if current_user.role!="admin": return "Forbidden",403
    subprocess.Popen(["restic","backup","/srv","/etc","/home"])
    audit("BACKUP")
    return redirect("/")

@app.route("/reboot")
@login_required
def reboot():
    if current_user.role!="admin": return "Forbidden",403
    audit("REBOOT")
    subprocess.Popen(["reboot"])
    return "Rebooting"

@app.route("/logout")
@login_required
def logout():
    audit("LOGOUT")
    logout_user()
    return redirect("/login")

if __name__=="__main__":
    app.run(host="0.0.0.0",port=PORT,ssl_context=("cert.pem","key.pem"))


