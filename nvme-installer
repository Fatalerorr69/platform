#!/bin/bash
set -e

CONFIG="/root/installer_runtime.conf"
LOG="/root/install.log"

exec > >(tee -a "$LOG") 2>&1

if [ ! -f "$CONFIG" ]; then
  echo "[ERROR] Konfigurační soubor nenalezen: $CONFIG"
  exit 1
fi

source "$CONFIG"

echo "===== START INSTALACE ====="
date

check_root() {
if [ "$EUID" -ne 0 ]; then
 echo "Spusť jako root!"
 exit 1
fi
}

check_root

base_setup() {
echo "[BASE] Aktualizace systému"
apt update && apt full-upgrade -y

echo "[BASE] Hostname"
hostnamectl set-hostname "$HOSTNAME"

echo "[BASE] Locale & timezone"
timedatectl set-timezone "$TIMEZONE"
sed -i "s/# $LOCALE/$LOCALE/" /etc/locale.gen
locale-gen
update-locale LANG=$LOCALE

echo "[BASE] User"
useradd -m -s /bin/bash "$USERNAME" || true
echo "$USERNAME:$PASSWORD" | chpasswd
usermod -aG sudo "$USERNAME"
}

security_setup() {
echo "[SECURITY] SSH hardening"
sed -i 's/^#\?PasswordAuthentication.*/PasswordAuthentication no/' /etc/ssh/sshd_config
sed -i 's/^#\?PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config
systemctl restart ssh

echo "[SECURITY] Firewall"
apt install -y ufw fail2ban
ufw default deny incoming
ufw default allow outgoing
ufw allow 22/tcp
ufw --force enable
systemctl enable --now fail2ban
}

docker_setup() {
echo "[DOCKER]"
curl -fsSL https://get.docker.com | sh
apt install -y docker-compose-plugin
usermod -aG docker "$USERNAME"
}

monitoring_setup() {
echo "[MONITORING]"
mkdir -p /srv/monitoring
docker run -d --restart always --name node-exporter -p 9100:9100 prom/node-exporter
}

nas_setup() {
echo "[NAS]"
apt install -y samba
mkdir -p /srv/nas/{public,family,admin,robot-data}
chmod -R 777 /srv/nas/public
}

smarthome_setup() {
echo "[SMARTHOME]"
docker run -d --restart always --name mosquitto -p 1883:1883 eclipse-mosquitto
docker run -d --restart always --name homeassistant --privileged -p 8123:8123 homeassistant/home-assistant
}

robot_setup() {
echo "[ROBOT]"
docker run -d --restart always --name nodered -p 1880:1880 nodered/node-red
}

ai_setup() {
echo "[AI MODE: $AI_MODE]"
mkdir -p /srv/ai
echo "$AI_MODE" > /srv/ai/mode.txt
}

webui_setup() {
echo "[WEBUI]"
apt install -y nginx
cat <<EOF >/var/www/html/index.html
<h1>RPi5 Server Dashboard</h1>
<ul>
<li>Monitoring</li>
<li>NAS</li>
<li>SmartHome</li>
<li>Robot</li>
<li>AI Mode: $AI_MODE</li>
</ul>
EOF
}

lab_pentest() {
echo "[LAB] Pentest"
apt install -y nmap hydra metasploit-framework sqlmap wireshark
}

lab_android() {
echo "[LAB] Android"
apt install -y adb apktool jadx
}

lab_network() {
echo "[LAB] Network Lab"
apt install -y iperf3 tcpdump mtr
}

lab_servers() {
echo "[LAB] Servers Lab"
apt install -y apache2 mariadb-server postgresql
}

lab_ai() {
echo "[LAB] AI Lab"
apt install -y python3-pip
pip3 install langchain llama-index
}

lab_sandbox() {
echo "[LAB] Sandbox"
apt install -y firejail qemu-system
}

lab_training() {
echo "[LAB] Training"
mkdir -p /srv/training
}

backup_system() {
if [ "$ENABLE_BACKUP" = "yes" ]; then
 echo "[BACKUP]"
 apt install -y restic
 mkdir -p /srv/backups
 restic init --repo /srv/backups/restic || true
 restic backup /srv /etc /home
fi
}

main() {

if [ "$INSTALL_BASE" = true ]; then base_setup; fi
if [ "$INSTALL_SECURITY" = true ]; then security_setup; fi
if [ "$INSTALL_DOCKER" = true ]; then docker_setup; fi
if [ "$INSTALL_MONITORING" = true ]; then monitoring_setup; fi
if [ "$INSTALL_NAS" = true ]; then nas_setup; fi
if [ "$INSTALL_SMARTHOME" = true ]; then smarthome_setup; fi
if [ "$INSTALL_ROBOT" = true ]; then robot_setup; fi
if [ "$INSTALL_AI" = true ]; then ai_setup; fi
if [ "$INSTALL_WEBUI" = true ]; then webui_setup; fi

if [ "$LAB_PENTEST" = true ]; then lab_pentest; fi
if [ "$LAB_ANDROID" = true ]; then lab_android; fi
if [ "$LAB_NETWORK" = true ]; then lab_network; fi
if [ "$LAB_SERVERS" = true ]; then lab_servers; fi
if [ "$LAB_AI" = true ]; then lab_ai; fi
if [ "$LAB_SANDBOX" = true ]; then lab_sandbox; fi
if [ "$LAB_TRAINING" = true ]; then lab_training; fi

backup_system

echo "===== INSTALACE DOKONČENA ====="
date

if [ "$AUTO_REBOOT" = "yes" ]; then
 reboot
fi
}

main


