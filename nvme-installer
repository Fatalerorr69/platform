from flask import Flask, render_template, request, redirect
import subprocess
import psutil
import os

app = Flask(__name__)

LOG_FILE = "/root/install.log"
AI_FILE = "/srv/ai/mode.txt"

def get_services():
    services = ["docker", "nginx", "ssh", "ufw", "fail2ban"]
    status = {}
    for s in services:
        try:
            out = subprocess.check_output(["systemctl","is-active",s]).decode().strip()
        except:
            out = "unknown"
        status[s] = out
    return status

@app.route("/")
def index():
    log = ""
    if os.path.exists(LOG_FILE):
        with open(LOG_FILE) as f:
            log = f.read()[-8000:]

    ai_mode = "N/A"
    if os.path.exists(AI_FILE):
        ai_mode = open(AI_FILE).read().strip()

    cpu = psutil.cpu_percent(interval=1)
    mem = psutil.virtual_memory().percent
    disk = psutil.disk_usage("/").percent

    return render_template(
        "index.html",
        log=log,
        ai_mode=ai_mode,
        cpu=cpu,
        mem=mem,
        disk=disk,
        services=get_services()
    )

@app.route("/set_ai", methods=["POST"])
def set_ai():
    mode = request.form["mode"]
    os.makedirs("/srv/ai", exist_ok=True)
    with open(AI_FILE,"w") as f:
        f.write(mode)
    return redirect("/")

@app.route("/backup")
def backup():
    subprocess.Popen(["restic","backup","/srv","/etc","/home"])
    return redirect("/")

@app.route("/reboot")
def reboot():
    subprocess.Popen(["reboot"])
    return "Rebooting..."

if __name__ == "__main__":
    app.run(host="0.0.0.0", port=8080)


