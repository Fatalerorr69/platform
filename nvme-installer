cat <<EOF > $CONFIG_FILE
TARGET_DISK="$TARGET_DISK"
HOSTNAME="$HOSTNAME"
USERNAME="$USERNAME"
PASSWORD="$PASSWORD"
LOCALE="$LOCALE"
TIMEZONE="$TIMEZONE"
AI_MODE="$AI_MODE"
AUTO_REBOOT="$AUTO_REBOOT"
ENABLE_BACKUP="$ENABLE_BACKUP"

INSTALL_BASE=$INSTALL_BASE
INSTALL_SECURITY=$INSTALL_SECURITY
INSTALL_DOCKER=$INSTALL_DOCKER
INSTALL_MONITORING=$INSTALL_MONITORING
INSTALL_NAS=$INSTALL_NAS
INSTALL_SMARTHOME=$INSTALL_SMARTHOME
INSTALL_ROBOT=$INSTALL_ROBOT
INSTALL_AI=$INSTALL_AI
INSTALL_WEBUI=$INSTALL_WEBUI

LAB_PENTEST=$LAB_PENTEST
LAB_ANDROID=$LAB_ANDROID
LAB_NETWORK=$LAB_NETWORK
LAB_SERVERS=$LAB_SERVERS
LAB_AI=$LAB_AI
LAB_SANDBOX=$LAB_SANDBOX
LAB_TRAINING=$LAB_TRAINING
EOF
}

