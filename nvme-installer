AUTO_REBOOT="yes"
ENABLE_BACKUP="yes"

INSTALL_BASE=true
INSTALL_SECURITY=true
INSTALL_DOCKER=true
INSTALL_MONITORING=false
INSTALL_NAS=false
INSTALL_SMARTHOME=false
INSTALL_ROBOT=false
INSTALL_AI=true
INSTALL_WEBUI=true

# LAB modules
LAB_PENTEST=false
LAB_ANDROID=false
LAB_NETWORK=false
LAB_SERVERS=false
LAB_AI=false
LAB_SANDBOX=false
LAB_TRAINING=false

