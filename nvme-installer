from flask import Flask, render_template, request, redirect, url_for
from flask_login import LoginManager, login_user, login_required, logout_user, UserMixin, current_user
import subprocess, psutil, json, os, datetime

app = Flask(__name__)
app.secret_key = "STRONG_SECRET_KEY"

login_manager = LoginManager()
login_manager.init_app(app)
login_manager.login_view = "login"

LOG_FILE="/root/install.log"
AI_FILE="/srv/ai/mode.txt"
AUDIT_LOG="/var/log/installer-web-audit.log"
USERS_FILE="/opt/installer-web-secure/users.json"

class User(UserMixin):
    def __init__(self, username, role):
        self.id = username
        self.role = role

def log_action(action):
    with open(AUDIT_LOG,"a") as f:
        f.write(f"{datetime.datetime.now()} {current_user.id} {action}\n")

def load_users():
    return json.load(open(USERS_FILE))

@login_manager.user_loader
def load_user(user_id):
    users = load_users()
    if user_id in users:
        return User(user_id, users[user_id]["role"])
    return None

@app.route("/login", methods=["GET","POST"])
def login():
    if request.method=="POST":
        users = load_users()
        u = request.form["username"]
        p = request.form["password"]
        if u in users and users[u]["password"]==p:
            login_user(User(u, users[u]["role"]))
            log_action("LOGIN")
            return redirect("/")
    return render_template("login.html")

@app.route("/logout")
@login_required
def logout():
    log_action("LOGOUT")
    logout_user()
    return redirect("/login")

@app.route("/")
@login_required
def index():
    log = open(LOG_FILE).read()[-8000:] if os.path.exists(LOG_FILE) else ""
    ai_mode = open(AI_FILE).read().strip() if os.path.exists(AI_FILE) else "N/A"

    cpu = psutil.cpu_percent(interval=1)
    mem = psutil.virtual_memory().percent
    disk = psutil.disk_usage("/").percent

    services = {}
    for s in ["docker","nginx","ssh","ufw","fail2ban"]:
        try:
            services[s]=subprocess.check_output(["systemctl","is-active",s]).decode().strip()
        except:
            services[s]="unknown"

    return render_template("index.html",log=log,ai_mode=ai_mode,cpu=cpu,mem=mem,disk=disk,services=services,role=current_user.role)

@app.route("/set_ai", methods=["POST"])
@login_required
def set_ai():
    if current_user.role!="admin":
        return "Forbidden",403
    mode=request.form["mode"]
    os.makedirs("/srv/ai",exist_ok=True)
    open(AI_FILE,"w").write(mode)
    log_action(f"SET_AI={mode}")
    return redirect("/")

@app.route("/backup")
@login_required
def backup():
    if current_user.role!="admin":
        return "Forbidden",403
    subprocess.Popen(["restic","backup","/srv","/etc","/home"])
    log_action("BACKUP")
    return redirect("/")

@app.route("/reboot")
@login_required
def reboot():
    if current_user.role!="admin":
        return "Forbidden",403
    log_action("REBOOT")
    subprocess.Popen(["reboot"])
    return "Rebooting..."

if __name__=="__main__":
    app.run(host="0.0.0.0", port=8443, ssl_context=("cert.pem","key.pem"))


